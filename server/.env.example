MONGODB_URI=mongodb://localhost:27017/monopoly
CLIENT_URL=http://localhost:3000
PORT=5004
SESSION_SECRET=change-me

# Room lifecycle
ROOM_IDLE_TIMEOUT_MS=900000
PENDING_HOST_CONNECT_MS=300000
PENDING_ROOMS_PER_SESSION=2
MAX_ACTIVE_ROOMS=200

# REST abuse protection
RATE_LIMIT_ROOM_CREATE_SESSION_PER_MIN=5
RATE_LIMIT_ROOM_CREATE_IP_PER_10_MIN=30
RATE_LIMIT_BOARD_MUTATE_PER_MIN=30
RATE_LIMIT_LOOKUP_PER_MIN=180

# Socket.IO abuse protection
RATE_LIMIT_SOCKET_CONNECT_PER_MIN=30
RATE_LIMIT_SOCKET_DEFAULT_PER_10_SEC=120
RATE_LIMIT_SOCKET_CHAT_PER_10_SEC=8
RATE_LIMIT_SOCKET_TRADE_PROPOSE_PER_MIN=10
RATE_LIMIT_SOCKET_TRADE_UPDATE_PER_10_SEC=20
RATE_LIMIT_SOCKET_TRADE_MSG_PER_10_SEC=10
RATE_LIMIT_SOCKET_AUCTION_BID_PER_10_SEC=20
RATE_LIMIT_SOCKET_AUCTION_PASS_PER_10_SEC=10
RATE_LIMIT_SOCKET_USERNAME_PER_MIN=6
RATE_LIMIT_SOCKET_COLOR_PER_MIN=12
RATE_LIMIT_SOCKET_RULES_PER_10_SEC=20
