# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Optional in local development because the client defaults to http://localhost:5004.
# Required in production when the frontend is deployed separately from the API.
VITE_API_URL=http://localhost:5004

# Optional. Set only if Socket.IO is served from a different origin than REST.
VITE_SOCKET_URL=http://localhost:5004

# Optional override if you want solo-start in a non-Vite-dev client build.
# VITE_ALLOW_SOLO_DEV_GAME=1
