[Unit]
Description=MONOPOLY Node/Socket.IO backend
After=network.target mongod.service
Wants=mongod.service

[Service]
Type=simple
User=monopoly
Group=monopoly
WorkingDirectory=/opt/monopoly/server
ExecStart=/usr/bin/node index.js
Restart=on-failure
RestartSec=3s
Environment=NODE_ENV=production
EnvironmentFile=/etc/monopoly/server.env
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
